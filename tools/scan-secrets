#!/usr/bin/env python3
"""scan-secrets: a credential/secret scanner for files about to be committed (built for the
session-transcript logs, but works on any text file). Used by the `capture-session` skill and
available as a pre-commit backstop.

It is intentionally a *gate with a human in the loop*, not an auto-redactor: every match is
surfaced with its `file:line` and a tight context window so a person can confirm it's benign
(e.g. auth *code* like `access_token=create_access_token(...)`, or course prose about API keys)
or abort. Exit code is 0 when clean, 1 when anything matches.

Heuristic by nature — false negatives are possible (it is not a guarantee), and on a security-
course corpus false positives are expected (the word "secret"/"token" is everywhere). That's why
nothing here auto-decides; it raises hits for review.

Usage:
  tools/scan-secrets <file> [<file> ...]
  tools/scan-secrets --window N <file>      # chars of context shown around each match (default 60)
"""
import argparse
import re
import sys

# (label, confidence, pattern). "high" = looks like real credential material (should essentially
# never be a false positive); "heuristic" = word-adjacent / assignment shapes that fire on code
# and prose too. Under pause-on-everything, both require human clearance.
PATTERNS = [
    ("anthropic-key",      "high",      re.compile(r"sk-ant-[A-Za-z0-9_-]{20,}")),
    ("openai-key",         "high",      re.compile(r"sk-[A-Za-z0-9]{32,}")),
    ("github-token",       "high",      re.compile(r"gh[posru]_[A-Za-z0-9]{36,}")),
    ("aws-access-key-id",  "high",      re.compile(r"AKIA[0-9A-Z]{16}")),
    ("google-api-key",     "high",      re.compile(r"AIza[0-9A-Za-z_-]{35}")),
    ("slack-token",        "high",      re.compile(r"xox[baprs]-[A-Za-z0-9-]{10,}")),
    ("private-key-block",  "high",      re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----")),
    ("jwt",                "high",      re.compile(r"eyJ[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{6,}")),
    ("bearer-token",       "heuristic", re.compile(r"[Bb]earer\s+[A-Za-z0-9._\-]{16,}")),
    ("secret-assignment",  "heuristic", re.compile(
        r"(?i)(password|passwd|secret|api[_-]?key|access[_-]?key|client[_-]?secret|token|authorization)"
        r"[\"']?\s*[:=]\s*[\"']?[A-Za-z0-9/_+\-]{12,}")),
]


def window(line, start, end, width):
    a = max(0, start - width)
    b = min(len(line), end + width)
    snippet = line[a:b].replace("\t", " ")
    return ("…" if a > 0 else "") + snippet + ("…" if b < len(line) else "")


def scan_file(path, width):
    hits = []
    try:
        with open(path, encoding="utf-8", errors="replace") as fh:
            for lineno, line in enumerate(fh, 1):
                line = line.rstrip("\n")
                for label, conf, rx in PATTERNS:
                    for m in rx.finditer(line):
                        hits.append((path, lineno, m.start(), label, conf, window(line, m.start(), m.end(), width)))
    except OSError as e:
        print(f"scan-secrets: cannot read {path}: {e}", file=sys.stderr)
    return hits


def main(argv):
    ap = argparse.ArgumentParser(description="Scan files for credential-shaped strings (human-reviewed gate).")
    ap.add_argument("files", nargs="+")
    ap.add_argument("--window", type=int, default=60, help="context chars shown around each match")
    args = ap.parse_args(argv)

    all_hits = []
    for f in args.files:
        all_hits.extend(scan_file(f, args.window))

    if not all_hits:
        print(f"scan-secrets: clean — no credential-shaped strings in {len(args.files)} file(s).")
        return 0

    high = [h for h in all_hits if h[4] == "high"]
    print(f"scan-secrets: ⚠ {len(all_hits)} match(es) need human review "
          f"({len(high)} high-confidence). Verify each line is benign (code/prose) or ABORT.\n")
    for path, lineno, col, label, conf, snip in all_hits:
        mark = "‼ HIGH" if conf == "high" else "·"
        print(f"  {mark} {path}:{lineno}:{col}  [{label}]\n      {snip}")
    print("\nNothing is committed until a human clears every line above.")
    return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
