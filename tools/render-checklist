#!/usr/bin/env python3
"""Render course/progress-checklist.md from meta/capability-map.yaml (R9.AC5).

The learner-facing progress checklist is *derived* from the capability map so the two never drift:
every can-do (C1–C17 + CV) becomes one tickable line under its stage, naming its home unit. The map
is the single source of truth; this is the build step that projects it into learner prose.

Usage:
  tools/render-checklist            # write course/progress-checklist.md
  tools/render-checklist --check    # don't write; fail if the file is stale vs the map
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _common import COURSE, META, load_yaml  # noqa: E402

OUT = COURSE / "progress-checklist.md"

HEADER = """\
<!-- GENERATED from meta/capability-map.yaml — do not hand-edit (R9.AC5).
     Regenerate with tools/render-checklist. -->
# Progress checklist

Tick a box when you can do it **unaided** and have proven it (a lab passed, or you
demonstrated it in the capstone). This is a map of the *work* you can do — not a
ranking of you. Each item names its **home unit**; `CV` is cross-cutting (every lab).
"""

FOOTER = """\
---

When every box is ticked and your capstone rubric agrees, you've cleared the bar this
course was built to clear. See `course/capstone/`.
"""


def render(cap):
    by_stage = {}
    for c in cap["capabilities"]:
        by_stage.setdefault(c["stage"], []).append(c)

    # The four ordered stages from the map, then any cross-cutting capabilities last.
    sections = [(s["id"], s["title"]) for s in cap["stages"]]
    if any(c["stage"] == "cross-cutting" for c in cap["capabilities"]):
        sections.append(("cross-cutting", "Cross-cutting"))

    parts = [HEADER]
    for stage_id, title in sections:
        parts.append(f"## {title}\n")
        lines = []
        for c in by_stage.get(stage_id, []):
            home = "every lab" if c["home_unit"] == "every-lab" else c["home_unit"]
            lines.append(f"- [ ] **{c['id']}** — I can {c['statement']}. _(↦ {home})_")
        parts.append("\n".join(lines) + "\n")
    parts.append(FOOTER)
    return "\n".join(parts)


def main(argv):
    cap = load_yaml(META / "capability-map.yaml")
    rendered = render(cap)
    if "--check" in argv:
        current = OUT.read_text(encoding="utf-8") if OUT.exists() else ""
        if current != rendered:
            sys.stderr.write(
                "error: course/progress-checklist.md is stale vs meta/capability-map.yaml; "
                "run tools/render-checklist\n"
            )
            return 1
        print("render-checklist: progress-checklist.md is in sync with the capability map")
        return 0
    OUT.write_text(rendered, encoding="utf-8")
    print(f"render-checklist: wrote {OUT.relative_to(COURSE.parent)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
