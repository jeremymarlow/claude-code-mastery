#!/usr/bin/env python3
"""Generate meta/version-data.json from meta/version-data.yaml (the YAML is authoritative).

Prose and the checks read meta/version-data.yaml; the .json twin exists only so tooling that
prefers JSON has a copy (design §5). Because it was hand-regenerated, it drifted silently once
(L14: a stale `custom-commands` value). This makes the twin a *generated* artifact: `make render`
rewrites it and `make check` (via --check) fails if the committed twin != render(yaml), so the two
can no longer diverge.

The serialization is pinned to match the committed format byte-for-byte (indent=2,
ensure_ascii=True, trailing newline) so --check is a true equality gate, not a reformat.

Usage:
  tools/render-vd-json            # write meta/version-data.json from the YAML
  tools/render-vd-json --check    # don't write; fail if the twin is stale vs the YAML
"""
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _common import META, load_yaml  # noqa: E402

SRC = META / "version-data.yaml"
OUT = META / "version-data.json"


def render(data) -> str:
    return json.dumps(data, indent=2, ensure_ascii=True) + "\n"


def main(argv):
    rendered = render(load_yaml(SRC))
    if "--check" in argv:
        current = OUT.read_text(encoding="utf-8") if OUT.exists() else ""
        if current != rendered:
            sys.stderr.write(
                "error: meta/version-data.json is stale vs meta/version-data.yaml; "
                "run tools/render-vd-json (or make render)\n"
            )
            return 1
        print("render-vd-json: version-data.json is in sync with version-data.yaml")
        return 0
    OUT.write_text(rendered, encoding="utf-8")
    print(f"render-vd-json: wrote {OUT.relative_to(META.parent)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
